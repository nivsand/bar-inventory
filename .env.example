# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (Neon / PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE_URL  -> pooled connection (used by the app at runtime).
# DIRECT_URL    -> direct (non-pooled) connection (used by `prisma migrate`).
# On Neon, copy both from the dashboard. The pooled host contains "-pooler".
# Locally (plain Postgres) you can set DIRECT_URL to the same value as DATABASE_URL.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/bar_inventory?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/bar_inventory?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────────────────────────────────────
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# NEXTAUTH_URL must match the URL the app is actually served from.
#  - Local dev: set it to your real dev port, e.g. http://localhost:3000
#    (if you run `next dev -p 3001`, use http://localhost:3001).
#  - Vercel: set it to your production domain, e.g. https://your-app.vercel.app
#    (Vercel preview deployments work automatically; logout uses a relative
#     redirect so it is resilient to host/port differences.)
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────────────────
# OCR (optional). Leave OCR_PROVIDER blank to use the built-in stub parser.
# ─────────────────────────────────────────────────────────────────────────────
OCR_PROVIDER=""          # "" | "openai" | "google" | "azure"
OCR_API_KEY=""
